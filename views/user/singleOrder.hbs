<link rel="stylesheet" href="/stylesheets/profile.css">

<section class="orders-shell single-order-shell">
    <div class="container mt-4">
        <div class="order-card-modern single-order-products-card">
            <div class="single-order-header">
                <div>
                    <span class="shop-eyebrow">Order details</span>
                    <h2>Your items</h2>
                </div>
                {{#if (eq order.orderStatus "adminAcceptCancel")}}
                <span class="order-status-pill status-cancelled">Order Cancelled</span>
                {{else}}{{#if (eq order.orderStatus "userCancelPending")}}
                <span class="order-status-pill status-pending">Cancel In Progress</span>
                {{else}}{{#if (eq order.orderStatus "returnPending")}}
                <span class="order-status-pill status-pending">Return In Progress</span>
                {{else}}{{#if (eq order.orderStatus "returnConfirmed")}}
                <span class="order-status-pill status-success">Returned</span>
                {{else}}
                <span class="order-status-pill status-success">{{order.orderStatus}}</span>
                {{/if}}{{/if}}{{/if}}{{/if}}
            </div>

            <div class="single-order-products-list">
                {{#each order.products}}
                <article class="single-order-product-row">
                    <div class="single-order-product-image">
                        <img src="/product-images/{{product.Images.[0]}}.jpg" alt="{{product.product}}">
                    </div>
                    <div class="single-order-product-copy">
                        <h3>{{product.product}}</h3>
                        <p class="single-order-brand">{{product.brand}}</p>
                        <div class="single-order-price-row">
                            <strong>&#8377;{{product.offerPrice}}</strong>
                            <span>&#8377;{{product.price}}</span>
                        </div>
                        <div class="single-order-meta">
                            <span>Size: {{size}}</span>
                            <span>Quantity: {{quantity}}</span>
                        </div>
                        <div class="single-order-line-actions">
                            {{#if isCancelled}}
                            <span class="order-status-pill status-cancelled">Cancelled</span>
                            {{else}}{{#if isCancelPending}}
                            <span class="order-status-pill status-pending">Cancellation Pending</span>
                            {{else}}{{#if canCancel}}
                            <a href="/cancel-order/{{../order._id}}" class="single-order-inline-link">Select item to cancel</a>
                            {{else}}
                            <span class="single-order-inline-note">Cancellation unavailable</span>
                            {{/if}}{{/if}}{{/if}}
                        </div>
                    </div>
                </article>
                {{/each}}
            </div>
        </div>

        {{#if (eq order.orderStatus 'adminAcceptCancel')}}{{else}}
        <div class="order-card-modern single-order-track-card">
            <div class="single-order-section-head">
                <h3>Track order</h3>
                <p>Follow your shipment status from placement to delivery.</p>
            </div>

            {{#if (eq order.orderStatus 'orderPlaced')}}
            <div class="order-progress">
                <div class="order-progress-step is-active">
                    <div class="order-progress-dot"></div>
                    <span>Order Placed</span>
                </div>
                <div class="order-progress-line"></div>
                <div class="order-progress-step">
                    <div class="order-progress-dot"></div>
                    <span>Shipped</span>
                </div>
                <div class="order-progress-line"></div>
                <div class="order-progress-step">
                    <div class="order-progress-dot"></div>
                    <span>Out for delivery</span>
                </div>
                <div class="order-progress-line"></div>
                <div class="order-progress-step">
                    <div class="order-progress-dot"></div>
                    <span>Delivered</span>
                </div>
            </div>
            {{else}}{{#if (eq order.orderStatus 'shipped')}}
            <div class="order-progress">
                <div class="order-progress-step is-active">
                    <div class="order-progress-dot"></div>
                    <span>Order Placed</span>
                </div>
                <div class="order-progress-line is-active"></div>
                <div class="order-progress-step is-active">
                    <div class="order-progress-dot"></div>
                    <span>Shipped</span>
                </div>
                <div class="order-progress-line"></div>
                <div class="order-progress-step">
                    <div class="order-progress-dot"></div>
                    <span>Out for delivery</span>
                </div>
                <div class="order-progress-line"></div>
                <div class="order-progress-step">
                    <div class="order-progress-dot"></div>
                    <span>Delivered</span>
                </div>
            </div>
            {{else}}{{#if (eq order.orderStatus 'outForDelivery')}}
            <div class="order-progress">
                <div class="order-progress-step is-active">
                    <div class="order-progress-dot"></div>
                    <span>Order Placed</span>
                </div>
                <div class="order-progress-line is-active"></div>
                <div class="order-progress-step is-active">
                    <div class="order-progress-dot"></div>
                    <span>Shipped</span>
                </div>
                <div class="order-progress-line is-active"></div>
                <div class="order-progress-step is-active">
                    <div class="order-progress-dot"></div>
                    <span>Out for delivery</span>
                </div>
                <div class="order-progress-line"></div>
                <div class="order-progress-step">
                    <div class="order-progress-dot"></div>
                    <span>Delivered</span>
                </div>
            </div>
            {{else}}{{#if (eq order.orderStatus 'Delivered')}}
            <div class="order-progress">
                <div class="order-progress-step is-active">
                    <div class="order-progress-dot"></div>
                    <span>Order Placed</span>
                </div>
                <div class="order-progress-line is-active"></div>
                <div class="order-progress-step is-active">
                    <div class="order-progress-dot"></div>
                    <span>Shipped</span>
                </div>
                <div class="order-progress-line is-active"></div>
                <div class="order-progress-step is-active">
                    <div class="order-progress-dot"></div>
                    <span>Out for delivery</span>
                </div>
                <div class="order-progress-line is-active"></div>
                <div class="order-progress-step is-active">
                    <div class="order-progress-dot"></div>
                    <span>Delivered</span>
                </div>
            </div>
            {{/if}}{{/if}}{{/if}}{{/if}}
        </div>
        {{/if}}

        <div class="single-order-bottom-grid">
            <div class="order-card-modern single-order-address-card">
                <div class="single-order-section-head">
                    <h3>Delivery Address</h3>
                    <p>Where this order is headed.</p>
                </div>
                <div class="single-order-address">
                    <strong>{{order.Address.name}}</strong>
                    <span>{{order.Address.address}}</span>
                    <span>{{order.Address.town}}</span>
                    <span>{{order.Address.state}}</span>
                    <span>{{order.Address.pincode}}</span>
                    <span>{{order.Address.phone}}</span>
                    <span>{{order.Address.email}}</span>
                </div>
            </div>

            <div class="order-card-modern single-order-actions-card">
                <div class="single-order-section-head">
                    <h3>More Actions</h3>
                    <p>Manage invoice, cancellations, or returns.</p>
                </div>

                <div class="single-order-action-stack">
                    {{#if (eq order.orderStatus 'orderPlaced')}}
                    <a href="/invoice/{{order._id}}" target="_blank" class="single-order-action-btn action-dark">Download Invoice</a>
                    {{/if}}
                    {{#if (eq order.orderStatus 'shipped')}}
                    <a href="/invoice/{{order._id}}" target="_blank" class="single-order-action-btn action-dark">Download Invoice</a>
                    {{/if}}
                    {{#if (eq order.orderStatus 'outForDelivery')}}
                    <a href="/invoice/{{order._id}}" target="_blank" class="single-order-action-btn action-dark">Download Invoice</a>
                    {{/if}}
                    {{#if (eq order.orderStatus 'Delivered')}}
                    <a href="/invoice/{{order._id}}" target="_blank" class="single-order-action-btn action-dark">Download Invoice</a>
                    {{/if}}

                    {{#if (eq order.orderStatus 'adminAcceptCancel')}}
                    <div class="single-order-note note-danger">Your order has been cancelled.</div>
                    {{else}}{{#if (eq order.orderStatus 'userCancelPending')}}
                    <div class="single-order-note note-warning">Your cancellation request is being processed.</div>
                    {{else}}{{#if (eq order.orderStatus 'Delivered')}}
                    <a data-bs-toggle="modal" data-bs-target="#staticBackdrop" class="single-order-action-btn action-danger">Return Order</a>
                    {{else}}{{#if (eq order.orderStatus "returnPending")}}
                    <div class="single-order-note note-warning">Your return request is being processed.</div>
                    {{else}}{{#if (eq order.orderStatus "returnConfirmed")}}
                    <div class="single-order-note note-success">Order returned. The refund has been moved to your wallet.</div>
                    {{else}}
                    <a href="/cancel-order/{{order._id}}" class="single-order-action-btn action-danger">Choose Items To Cancel</a>
                    {{/if}}{{/if}}{{/if}}{{/if}}{{/if}}
                </div>
            </div>
        </div>
    </div>
</section>

<div class="modal fade" id="staticBackdrop" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1"
    aria-labelledby="staticBackdropLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="staticBackdropLabel">Return Order</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <ol style="list-style: decimal;">
                    <li><a onclick="returnPro(this.innerHTML,'{{order._id}}')">Don't want the product anymore</a></li>
                    <li><a onclick="returnPro(this.innerHTML,'{{order._id}}')">Quality of the product not as expected</a></li>
                    <li><a onclick="returnPro(this.innerHTML,'{{order._id}}')">Recived wrong item</a></li>
                    <li><a onclick="returnPro(this.innerHTML,'{{order._id}}')">Don't like the size</a></li>
                    <li><a onclick="returnPro(this.innerHTML,'{{order._id}}')">Recived a damaged Item</a></li>
                    <li><a onclick="returnPro(this.innerHTML,'{{order._id}}')">Product is missing in the package</a></li>
                </ol>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary">Understood</button>
            </div>
        </div>
    </div>
</div>

<script>
    function returnPro(reason, id) {
        $.ajax({
            url: '/return',
            method: 'POST',
            data: { reason: reason, id: id },
            success: () => {
                location.reload()
            }
        })
    }
</script>
