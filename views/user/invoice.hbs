        .invoice-cell-money {
            font-size: 10px;
        }

        .invoice-summary-shell,
        .invoice-address-grid,
        .invoice-meta-grid,
        .invoice-table-wrap,
        .invoice-total-card,
        .invoice-note-card {
            page-break-inside: avoid;
            break-inside: avoid;
        }
    }
</style>
