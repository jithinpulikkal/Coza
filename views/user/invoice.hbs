<div class="invoice-page">
    <div class="invoice-card">
        <header class="invoice-header">
            <div class="invoice-brand-block">
                <span class="invoice-eyebrow">Retail Invoice</span>
                <h1>COZA Store</h1>
                <p class="invoice-subtitle">A polished summary of your purchase.</p>
            </div>
            <div class="invoice-header-side">
                <div class="invoice-status">Paid</div>
                <div class="invoice-number-chip">#{{order._id}}</div>
            </div>
        </header>

        <section class="invoice-intro">
            <p>Hello <strong>{{order.username}}</strong>, thanks for shopping with us.</p>
        </section>

        <section class="invoice-meta-grid invoice-doc-grid">
            <div class="invoice-meta-card">
                <span>Invoice No.</span>
                <strong>{{order._id}}</strong>
            </div>
            <div class="invoice-meta-card">
                <span>Invoice Date</span>
                <strong>{{order.date}}</strong>
            </div>
            <div class="invoice-meta-card">
                <span>Customer</span>
                <strong>{{order.username}}</strong>
            </div>
        </section>

        <section class="invoice-address-grid">
            <div class="invoice-address-card">
                <span class="invoice-label">Billed To</span>
                <strong>{{order.Address.name}}</strong>
                <p>
                    {{order.Address.address}}<br>
                    {{order.Address.town}}<br>
                    {{order.Address.pincode}}<br>
                    {{order.Address.state}}<br>
                    {{order.Address.email}}
                </p>
            </div>
            <div class="invoice-address-card invoice-address-store">
                <span class="invoice-label">From</span>
                <strong>COZA Store</strong>
                <p>
                    Online Fashion Store<br>
                    Support Desk<br>
                    coza.store.connect@gmail.com
                </p>
            </div>
        </section>

        <section class="invoice-items-section">
            <div class="invoice-section-head">
                <h2>Items</h2>
                <span>{{order.products.length}} item(s)</span>
            </div>

            <div class="invoice-table-wrap">
                <table class="invoice-table">
                    <colgroup>
                        <col class="invoice-col-item">
                        <col class="invoice-col-mrp">
                        <col class="invoice-col-discount">
                        <col class="invoice-col-qty">
                        <col class="invoice-col-total">
                    </colgroup>
                    <thead>
                        <tr>
                            <th>Item</th>
                            <th>MRP</th>
                            <th>Discount</th>
                            <th>Qty</th>
                            <th class="align-right">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each order.products}}
                        <tr>
                            <td>
                                <div class="invoice-item-cell">
                                    <strong>{{product.product}}</strong>
                                    <span>{{product.brand}}</span>
                                </div>
                            </td>
                            <td class="invoice-cell-money">&#8377;{{product.price}}</td>
                            <td class="invoice-cell-discount">{{product.discount}}% off</td>
                            <td>{{quantity}}</td>
                            <td class="align-right invoice-cell-money">&#8377;{{mul quantity product.offerPrice}}</td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
        </section>

        <section class="invoice-summary-shell">
            <div class="invoice-note-card">
                <span class="invoice-label">Note</span>
                <p>This invoice is generated electronically and is valid without a signature.</p>
            </div>

            <div class="invoice-total-card">
                <div class="invoice-total-heading">
                    <span class="invoice-label">Summary</span>
                    <strong>Payment Details</strong>
                </div>
                <div class="invoice-total-row">
                    <span>MRP Subtotal</span>
                    <strong>&#8377;{{order.subTotal}}</strong>
                </div>
                <div class="invoice-total-row">
                    <span>Total Discount</span>
                    <strong>- &#8377;{{minus order.subTotal order.discTotal}}</strong>
                </div>
                <div class="invoice-total-row">
                    <span>Amount After Discount</span>
                    <strong>&#8377;{{order.discTotal}}</strong>
                </div>
                <div class="invoice-total-row">
                    <span>Shipping</span>
                    <strong>&#8377;0.00</strong>
                </div>
                <div class="invoice-total-row grand-total">
                    <span>Payable Total</span>
                    <strong>&#8377;{{order.discTotal}}</strong>
                </div>
            </div>
        </section>
    </div>
</div>

<script>
    window.onload = function () {
        window.print()
    }
</script>

<style>
