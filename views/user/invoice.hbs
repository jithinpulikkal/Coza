        --invoice-text: #172126;
        --invoice-muted: #6f777a;
        --invoice-line: rgba(23, 33, 38, 0.12);
        --invoice-accent: #0f766e;
        --invoice-accent-soft: rgba(15, 118, 110, 0.1);
        --invoice-surface: rgba(255, 255, 255, 0.96);
        --invoice-shadow: 0 24px 48px rgba(15, 23, 31, 0.08);
    }

    * {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        font-family: Poppins, Arial, sans-serif;
        color: var(--invoice-text);
        background:
            radial-gradient(circle at top left, rgba(196, 220, 224, 0.45), transparent 28%),
            radial-gradient(circle at top right, rgba(247, 223, 162, 0.32), transparent 24%),
            #f5f1e8;
    }

    .invoice-page {
        min-height: 100vh;
        padding: 32px 20px;
    }

    .invoice-card {
        width: min(980px, 100%);
        margin: 0 auto;
        background: var(--invoice-surface);
        border: 1px solid rgba(255, 255, 255, 0.82);
        border-radius: 32px;
        box-shadow: var(--invoice-shadow);
        padding: 36px 38px 40px;
    }

    .invoice-header,
    .invoice-meta-grid,
    .invoice-address-grid,
    .invoice-total-row,
    .invoice-section-head {
        display: flex;
    }

    .invoice-header {
        justify-content: space-between;
        gap: 18px;
        align-items: flex-start;
        padding-bottom: 24px;
        border-bottom: 1px solid var(--invoice-line);
    }

    .invoice-brand-block {
        max-width: 560px;
    }

    .invoice-header-side {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 10px;
    }

    .invoice-eyebrow,
    .invoice-label {
        display: inline-block;
        font-size: 11px;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--invoice-accent);
        font-weight: 700;
    }

    .invoice-header h1 {
        margin: 10px 0 8px;
        font-size: clamp(2rem, 4vw, 3rem);
        line-height: 0.98;
    }

    .invoice-subtitle,
    .invoice-intro p,
    .invoice-address-card p,
    .invoice-note-card p {
        color: var(--invoice-muted);
    }

    .invoice-subtitle,
    .invoice-intro p,
    .invoice-note-card p {
        margin: 0;
    }

    .invoice-status {
        min-height: 42px;
        padding: 0 18px;
        border-radius: 999px;
        background: var(--invoice-accent-soft);
        color: var(--invoice-accent);
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        white-space: nowrap;
    }

    .invoice-number-chip {
        min-height: 34px;
        padding: 0 14px;
        border-radius: 999px;
        background: rgba(23, 33, 38, 0.06);
        color: var(--invoice-text);
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        white-space: nowrap;
    }

    .invoice-intro {
        padding: 22px 0 18px;
    }

    .invoice-meta-grid,
    .invoice-address-grid {
        gap: 18px;
    }

    .invoice-summary-shell {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 420px;
        gap: 22px;
        align-items: start;
    }

    .invoice-meta-grid,
    .invoice-address-grid {
        margin-bottom: 18px;
    }

    .invoice-doc-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 18px;
    }

    .invoice-meta-card,
    .invoice-address-card,
    .invoice-note-card,
    .invoice-total-card {
        background: rgba(248, 249, 249, 0.9);
        border: 1px solid var(--invoice-line);
        border-radius: 24px;
        padding: 18px 20px;
    }

    .invoice-meta-card,
    .invoice-address-card {
        flex: 1;
    }

    .invoice-meta-card span,
    .invoice-address-card strong {
        display: block;
    }

    .invoice-meta-card span {
        font-size: 0.85rem;
        color: var(--invoice-muted);
        margin-bottom: 6px;
    }

    .invoice-meta-card strong,
    .invoice-address-card strong,
    .invoice-total-row strong {
        font-size: 1rem;
    }

    .invoice-address-card strong {
        margin: 8px 0 8px;
    }

    .invoice-address-card p {
        line-height: 1.7;
        margin: 0;
    }

    .invoice-items-section {
        margin-top: 10px;
        padding: 20px 0 14px;
    }

    .invoice-section-head {
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        margin-bottom: 16px;
    }

    .invoice-section-head h2 {
        margin: 0;
        font-size: 1.45rem;
    }

    .invoice-section-head span {
        color: var(--invoice-muted);
        font-weight: 600;
    }

    .invoice-table-wrap {
        overflow: hidden;
        border: 1px solid var(--invoice-line);
        border-radius: 24px;
        background: rgba(255, 255, 255, 0.92);
    }

    .invoice-table {
        width: 100%;
        border-collapse: collapse;
        table-layout: fixed;
    }

    .invoice-col-item {
        width: 40%;
    }

    .invoice-col-mrp {
        width: 14%;
    }

    .invoice-col-discount {
        width: 16%;
    }

    .invoice-col-qty {
        width: 8%;
    }

    .invoice-col-total {
        width: 22%;
    }

    .invoice-table th,
    .invoice-table td {
        padding: 16px 18px;
        border-bottom: 1px solid var(--invoice-line);
        text-align: left;
        vertical-align: middle;
    }

    .invoice-table th {
        font-size: 0.84rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--invoice-muted);
        background: rgba(248, 249, 249, 0.92);
        white-space: nowrap;
    }

    .invoice-table tbody tr:last-child td {
        border-bottom: none;
    }

    .invoice-table th:nth-child(n + 2):not(:last-child),
    .invoice-table td:nth-child(n + 2):not(:last-child) {
        text-align: center;
    }

    .invoice-item-cell {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .invoice-item-cell strong {
        color: var(--invoice-text);
        font-size: 0.98rem;
    }

    .invoice-item-cell span {
        color: var(--invoice-muted);
        font-size: 0.88rem;
    }

    .invoice-cell-money {
        font-weight: 700;
        color: var(--invoice-text);
        white-space: nowrap;
    }

    .invoice-cell-discount {
        color: #b45309;
        font-weight: 700;
        white-space: nowrap;
    }

    .align-right {
        text-align: right !important;
    }

    .invoice-note-card {
        min-height: 188px;
        align-self: start;
    }

    .invoice-total-card {
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 14px;
        background: #fff;
        align-self: start;
    }

    .invoice-total-heading {
        display: flex;
        flex-direction: column;
        gap: 6px;
        padding-bottom: 10px;
        border-bottom: 1px solid var(--invoice-line);
    }

    .invoice-total-heading strong {
        color: var(--invoice-text);
        font-size: 1.05rem;
    }

    .invoice-total-row {
        justify-content: space-between;
        align-items: center;
        gap: 14px;
        color: var(--invoice-muted);
    }

    .invoice-total-row strong {
        color: var(--invoice-text);
    }

    .grand-total {
        margin-top: 6px;
        padding-top: 16px;
        border-top: 1px solid var(--invoice-line);
        color: var(--invoice-text);
    }

    .grand-total strong {
        color: var(--invoice-accent);
        font-size: 1.18rem;
    }

    @media (max-width: 767px) {
        .invoice-card {
            padding: 24px 20px 26px;
            border-radius: 24px;
        }

        .invoice-header,
        .invoice-address-grid,
        .invoice-section-head {
            flex-direction: column;
        }

        .invoice-header-side {
            align-items: flex-start;
        }

        .invoice-doc-grid {
            grid-template-columns: 1fr;
        }

        .invoice-summary-shell {
            grid-template-columns: 1fr;
        }

        .invoice-table th,
        .invoice-table td {
            padding: 12px 10px;
            font-size: 0.92rem;
        }

        .invoice-table-wrap {
            overflow-x: auto;
        }

        .invoice-table {
            min-width: 760px;
        }
    }

    @media print {
        body {
            background: #fff;
        }

        .invoice-page {
            padding: 0;
        }

        .invoice-card {
            width: 100%;
            margin: 0;
            border: none;
            border-radius: 0;
            box-shadow: none;
            padding: 18px 8px 0;
        }

        .invoice-table-wrap {
            overflow: visible;
            border-radius: 18px;
        }

        .invoice-table {
            width: 100%;
            min-width: 0;
            table-layout: fixed;
        }

        .invoice-col-item {
            width: 38%;
        }

        .invoice-col-mrp {
            width: 14%;
        }

        .invoice-col-discount {
            width: 16%;
        }

        .invoice-col-qty {
            width: 8%;
        }

        .invoice-col-total {
            width: 24%;
        }

        .invoice-table th,
        .invoice-table td {
