<div class="container shop-shell shop-page-shell">
    <div class="shop-layout">
        <aside class="shop-sidebar d-none d-md-block">
            <div class="filter-panel shop-filter-card">
                <div class="shop-filter-header">
                    <div>
                        <span class="shop-eyebrow">Refine your picks</span>
                        <h3>Filter</h3>
                    </div>
                    {{#if option}}
                    <a href="/disable-filter" class="shop-clear-filter">Clear</a>
                    {{/if}}
                </div>

                {{#if option}}
                <div class="shop-active-filter" id="opt">{{option}}</div>
                {{else}}
                <p class="shop-filter-hint" id="opt">Choose a category or price range</p>
                {{/if}}

                <div class="shop-filter-block">
                    <h5>Categories</h5>
                    <div class="shop-filter-links">
                        {{#each category}}
                        <a class="cate-list" id="{{[]}}" href="/filter/category/{{[]}}">{{[]}}</a>
                        {{/each}}
                    </div>
                </div>

                <div class="shop-filter-block">
                    <h5>Price Range</h5>
                    <div class="shop-filter-links">
                        <a class="cate-list" id="1000" href="/filter/price/1000">Under 1000</a>
                        <a class="cate-list" id="1000-2000" href="/filter/price/1000-2000">1000 - 2000</a>
                        <a class="cate-list" id="2000-3000" href="/filter/price/2000-3000">2000 - 3000</a>
                        <a class="cate-list" id="3000-4000" href="/filter/price/3000-4000">3000 - 4000</a>
                        <a class="cate-list" id="4000-5000" href="/filter/price/4000-5000">4000 - 5000</a>
                        <a class="cate-list" id="5000" href="/filter/price/5000">Above 5000</a>
                    </div>
                </div>
            </div>
        </aside>

        <section class="shop-main">
            <div class="d-flex d-md-none justify-content-between align-items-center shop-mobile-tools">
                <div>
                    <span class="shop-eyebrow">Browse smarter</span>
                    <h4 class="mb-0">Shop</h4>
                </div>
                <div class="btn-group">
                    <button type="button" class="shop-mobile-filter-btn dropdown-toggle" data-bs-toggle="dropdown"
                        data-bs-display="static" aria-expanded="false">
                        Filter{{#if option}}: {{option}}{{/if}}
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shop-mobile-dropdown">
                        <li class="shop-mobile-dropdown-title">Categories</li>
                        {{#each category}}
                        <li><a href="/filter/category/{{[]}}" class="dropdown-item">{{[]}}</a></li>
                        {{/each}}
                        <li><hr class="dropdown-divider"></li>
                        <li class="shop-mobile-dropdown-title">Price Range</li>
                        <li><a class="dropdown-item" id="1000" href="/filter/price/1000">Under 1000</a></li>
                        <li><a class="dropdown-item" id="1000-2000" href="/filter/price/1000-2000">1000 - 2000</a></li>
                        <li><a class="dropdown-item" id="2000-3000" href="/filter/price/2000-3000">2000 - 3000</a></li>
                        <li><a class="dropdown-item" id="3000-4000" href="/filter/price/3000-4000">3000 - 4000</a></li>
                        <li><a class="dropdown-item" id="4000-5000" href="/filter/price/4000-5000">4000 - 5000</a></li>
                        <li><a class="dropdown-item" id="5000" href="/filter/price/5000">Above 5000</a></li>
                        {{#if option}}
                        <li><hr class="dropdown-divider"></li>
                        <li><a href="/disable-filter" class="dropdown-item text-danger">Clear filter</a></li>
                        {{/if}}
                    </ul>
                </div>
            </div>

            <div class="shop-grid-shell shop-grid-panel">
                <div class="shop-toolbar">
                    <div class="shop-toolbar-copy">
                        <span class="shop-eyebrow">Curated catalogue</span>
                        <h2>Find the piece that fits your mood.</h2>
                        <p>Browse sharper edits, cleaner essentials, and standout accessories in one place.</p>
                    </div>

                    <div class="shop-toolbar-actions">
                        {{#if option}}
                        <div class="shop-active-pill">{{option}}</div>
                        {{/if}}
                        <label class="shop-sort-wrap" for="sortOption">
                            <span>Sort by</span>
                            <select oninput="sort()" id="sortOption" class="sort-select shop-sort-select">
                                <option value="">Relevance</option>
                                <option value="low" {{#if (eq sort 'low' )}} selected {{/if}}>Price low-high</option>
                                <option value="high" {{#if (eq sort 'high' )}} selected {{/if}}>Price high-low</option>
                            </select>
                        </label>
                    </div>
                </div>

                {{#if products}}
                <div class="row shop-products-row">
                    {{#each products}}
                    <div class="col-xl-3 col-lg-4 col-sm-6 mb-4">
                        <div class="card product-card-modern shop-card">
                            <a href="/product/{{_id}}" class="product-image-wrap shop-image-wrap">
                                <img id="img1" src="/product-images/{{Images.[0]}}.jpg" alt="{{product}}"
                                    onmouseover="this.src='/product-images/{{Images.[1]}}.jpg'"
                                    onmouseout="this.src='/product-images/{{Images.[0]}}.jpg'">
                            </a>
                            <a href="/product/{{_id}}" class="product-card-body shop-card-body text-decoration-none">
                                <p class="product-brand mb-2">{{brand}}</p>
                                <h3 class="product-name shop-product-name mb-2">{{product}}</h3>
                                <div class="product-price-row shop-price-row">
                                    <span class="product-original">₹{{price}}</span>
                                    <span class="product-offer">₹{{offerPrice}}</span>
                                </div>
                            </a>
                        </div>
                    </div>
                    {{/each}}
                </div>
                {{else}}
                <div class="shop-empty-state">
                    <span class="shop-eyebrow">Nothing matched</span>
                    <h3>No results found</h3>
                    <p>Try another category or clear the current filter to explore more products.</p>
                    <a href="/disable-filter" class="cta-primary">Reset Filters</a>
                </div>
                {{/if}}
            </div>

            <div class="shop-pagination-wrap">
                <nav aria-label="Page navigation">
                    <ul class="pagination">
                        {{#each pageArr}}
                        <li {{#if (eq ../page [])}} class="page-item active" {{else}} class="page-item" {{/if}}>
                            <a class="page-link" href="/pagination/{{[]}}">{{[]}}</a>
                        </li>
                        {{/each}}
                    </ul>
                </nav>
            </div>
        </section>
    </div>
</div>

<script>
    function sort() {
        let option = document.getElementById('sortOption').value
        $.ajax({
            url: '/select-sort',
            data: { sortOption: option },
            method: 'post',
            success: () => {
                location.href = '/shop'
            }
        })
    }

    let opt = document.getElementById('opt')
    if (opt && opt.innerHTML) {
        opt.style.color = 'black'
    }
</script>
