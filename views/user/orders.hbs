<div class="head-img d-flex align-items-center justify-content-center">
    <h1 class="text-white" style="text-shadow: 2px 1px 2px rgb(0, 0, 0);">Orders</h1>
</div>

<section class="orders-shell orders-page-shell">
    <div class="container mt-4">
        {{#if orderData}}
        <div class="orders-list">
            {{#each orderData}}
            <article class="order-card-modern orders-list-card">
                <div class="orders-card-top">
                    <div>
                        {{#if (eq orderStatus "adminAcceptCancel")}}
                        <span class="order-status-pill status-cancelled">Order Cancelled</span>
                        {{else}}{{#if (eq orderStatus "userCancelPending")}}
                        <span class="order-status-pill status-pending">Cancel In Progress</span>
                        {{else}}
                        <span class="order-status-pill status-success">{{orderStatus}}</span>
                        {{/if}}{{/if}}
                        <h3 class="orders-card-title">Order summary</h3>
                    </div>
                    <a href="/order/{{_id}}" class="cta-primary orders-view-btn">View Details</a>
                </div>

                <div class="orders-products-list">
                    {{#each products}}
                    <div class="orders-product-row">
                        <div class="orders-product-copy">
                            <h4>{{product.product}}</h4>
                            <p>{{product.brand}}</p>
                        </div>
                        <div class="orders-product-meta">Qty {{quantity}}</div>
                    </div>
                    {{/each}}
                </div>

                <div class="orders-summary-grid">
                    <div class="orders-summary-item">
                        <span>Total Amount</span>
                        <strong>&#8377;{{discTotal}}</strong>
                    </div>
                    <div class="orders-summary-item">
                        <span>Order Date</span>
                        <strong>{{Address.date}}</strong>
                    </div>
                    <div class="orders-summary-item">
                        <span>Items</span>
                        <strong>{{products.length}}</strong>
                    </div>
                </div>
            </article>
            {{/each}}
        </div>
        {{else}}
        <div class="order-card-modern orders-empty-state">
            <span class="shop-eyebrow">No recent purchases</span>
            <h3>No orders found</h3>
            <p>Your order history will appear here once you place your first order.</p>
            <a href="/shop" class="cta-primary">Start Shopping</a>
        </div>
        {{/if}}

        <div class="shop-pagination-wrap orders-pagination-wrap">
            <nav aria-label="Page navigation">
                <ul class="pagination">
                    {{#each pageArr}}
                    <li class="page-item {{#if (eq ../page this)}}active{{/if}}">
                        <a class="page-link" href="/paginationn/{{this}}">{{this}}</a>
                    </li>
                    {{/each}}
                </ul>
            </nav>
        </div>
    </div>
</section>
